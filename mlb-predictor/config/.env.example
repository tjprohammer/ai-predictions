# MLB Predictor - Environment Configuration
# ============================================
# Copy to .env and fill in your values:  cp .env.example .env

# ── Database ──────────────────────────────────────────────
# Default: SQLite (auto-created at <project>/db/mlb_predictor.sqlite3 when missing).
# Desktop builds use %LOCALAPPDATA%\MLBPredictor\db\mlb_predictor.sqlite3 when present.
# Optional: Postgres for advanced local development (see README / docs).
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/mlb
# DATABASE_URL=sqlite:///path/to/mlb_predictor.sqlite3

# ── Local API security (optional) ─────────────────────────
# When unset, /api/* is only reachable from this machine (loopback).
# Set a long random value if you bind the server beyond localhost and need remote JSON access.
# MLB_PREDICTOR_API_KEY=
# Send: Authorization: Bearer <key>  OR  X-MLB-Predictor-Api-Key: <key>

# ── External APIs (all optional) ──────────────────────────
# The Odds API – primary key (used first; falls back to _FALLBACK on 429/quota exhausted)
# https://the-odds-api.com/
THE_ODDS_API_KEY=your_odds_api_key_here

# The Odds API – fallback key (optional)
THE_ODDS_API_KEY_FALLBACK=

# Market ingest: skip Odds API calls when the slate already has fresh ``the_odds_api`` rows in
# game_markets / player_prop_markets (checked independently). Minutes of age; 0 = always call API.
# CLI ``--force-odds-api`` bypasses this skip.
# MARKET_INGEST_ODDS_API_FRESH_MINUTES=45

# Open-Meteo needs no key (free, non-commercial)
# https://open-meteo.com/

# ── Model / Feature Controls ─────────────────────────────
# Prior season used for Bayesian shrinkage
PRIOR_SEASON=2025
CURRENT_SEASON=2026

# Prior blend modes:
# - standard: normal 2025 -> 2026 blending
# - reduced: 2026 takes over faster with lighter 2025 influence
# - current_only: ignore prior-season blending entirely
PRIOR_BLEND_MODE=standard

# Additional global multiplier on prior influence.
# Lower values make current-season data take over faster.
PRIOR_WEIGHT_MULTIPLIER=1.0

# Rolling windows (games / PA / starts)
ROLLING_WINDOWS=7,14,30

# Separate full-weight thresholds for the three prior use cases
TEAM_FULL_WEIGHT_GAMES=30
PITCHER_FULL_WEIGHT_STARTS=10

# Minimum 2026 PA before trusting current-year stats fully
MIN_PA_FULL_WEIGHT=120

# ── Paths ─────────────────────────────────────────────────
DATA_DIR=./data
MODEL_DIR=./data/models
REPORT_DIR=./data/reports
FEATURE_DIR=./data/features
MANUAL_LINEUPS_CSV=./data/raw/manual_lineups.csv
MANUAL_MARKETS_CSV=./data/raw/manual_market_totals.csv
PARK_FACTORS_CSV=./db/seeds/park_factors.csv
MODEL_VERSION_PREFIX=v1

# Minutes before first pitch to stop refreshing markets, lineups, and probable starters
# (uses games.game_start_ts in UTC). Set to 0 to disable.
MLB_PREGAME_INGEST_LOCK_MINUTES=30

# Dashboard update jobs: max seconds per pipeline subprocess step (default 7200). Use 0 for no limit.
# MLB_PIPELINE_STEP_TIMEOUT_SEC=7200

# Green strip: optional minimum per-game board data certainty (0-100, from data_quality.certainty_pct).
# Leave unset for no extra gate. Example: only promote night games once inputs cross 84%.
# BOARD_GREEN_MIN_GAME_CERTAINTY_PCT=84
# When true, the first qualifying green pick per game is stored at ingest-lock time so later
# refreshes do not swap that matchup's headline pick (see db/migrations/028_board_green_snapshots.sql).
# BOARD_GREEN_SNAPSHOT_ENABLED=true

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
