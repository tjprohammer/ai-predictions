# MLB Predictor - Environment Configuration
# ============================================
# Copy to .env and fill in your values:  cp .env.example .env

# ── Database ──────────────────────────────────────────────
# Default: SQLite (auto-created at <project>/db/mlb_predictor.sqlite3 when missing).
# Desktop builds use %LOCALAPPDATA%\MLBPredictor\db\mlb_predictor.sqlite3 when present.
# Optional: Postgres for advanced local development (see README / docs).
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/mlb
# DATABASE_URL=sqlite:///path/to/mlb_predictor.sqlite3

# ── Local API security (optional) ─────────────────────────
# When unset, /api/* is only reachable from this machine (loopback).
# Set a long random value if you bind the server beyond localhost and need remote JSON access.
# MLB_PREDICTOR_API_KEY=
# Send: Authorization: Bearer <key>  OR  X-MLB-Predictor-Api-Key: <key>

# ── External APIs (all optional) ──────────────────────────
# The Odds API – primary key (used first; falls back to _FALLBACK on 429/quota exhausted)
# https://the-odds-api.com/
THE_ODDS_API_KEY=your_odds_api_key_here

# The Odds API – fallback key (optional)
THE_ODDS_API_KEY_FALLBACK=

# Market ingest: skip Odds API calls when the slate already has fresh ``the_odds_api`` rows in
# game_markets / player_prop_markets (checked independently). Minutes of age; 0 = always call API.
# CLI ``--force-odds-api`` bypasses this skip.
# MARKET_INGEST_ODDS_API_FRESH_MINUTES=45

# Open-Meteo needs no key (free, non-commercial)
# https://open-meteo.com/

# ── Model / Feature Controls ─────────────────────────────
# Prior season used for Bayesian shrinkage
PRIOR_SEASON=2025
CURRENT_SEASON=2026

# Prior blend modes:
# - standard: normal 2025 -> 2026 blending
# - reduced: 2026 takes over faster with lighter 2025 influence
# - current_only: ignore prior-season blending entirely
PRIOR_BLEND_MODE=standard

# Additional global multiplier on prior influence.
# Lower values make current-season data take over faster.
PRIOR_WEIGHT_MULTIPLIER=1.0

# Rolling windows (games / PA / starts)
ROLLING_WINDOWS=7,14,30

# Separate full-weight thresholds for the three prior use cases
TEAM_FULL_WEIGHT_GAMES=30
PITCHER_FULL_WEIGHT_STARTS=10

# Minimum 2026 PA before trusting current-year stats fully
MIN_PA_FULL_WEIGHT=120

# ── Paths ─────────────────────────────────────────────────
DATA_DIR=./data
MODEL_DIR=./data/models
REPORT_DIR=./data/reports
FEATURE_DIR=./data/features
MANUAL_LINEUPS_CSV=./data/raw/manual_lineups.csv
MANUAL_MARKETS_CSV=./data/raw/manual_market_totals.csv
PARK_FACTORS_CSV=./db/seeds/park_factors.csv
MODEL_VERSION_PREFIX=v1

# Minutes before first pitch to stop mutating markets, lineups, and probable starters
# (uses games.game_start_ts in UTC). Set to 0 to disable (lines keep updating until game time; heavy API use).
# Default 10: odds/features refresh until ~T-10, then DB state is preserved through live/final — EV stops drifting late,
# and Daily Results refresh grades against that stable snapshot as long as you do not re-run predict with new inputs.
MLB_PREGAME_INGEST_LOCK_MINUTES=10

# Green strip ranking: composite_v1 blends EV, edge, certainty, game certainty, model prob, trust, optional action_score.
# ev_gates = legacy sort by weighted EV only.
# Set false to hide First 5 away/home team total O/U from the main board (default: show).
# BOARD_INCLUDE_FIRST_FIVE_TEAM_TOTALS=false
# BOARD_GREEN_SELECTION_MODE=composite_v1
# Optional floor 0–1 for composite_v1 (unset = no extra filter beyond EV gates + soft strip rules).
# BOARD_GREEN_COMPOSITE_MIN=0.48

# Board hero "Picks of the day" (strict positives only, A/B trust, one per game). Defaults: min model P 56%, max 3.
# PICK_OF_THE_DAY_MIN_MODEL_PROB=0.56
# One best PoD per game for the full slate (default true). false = cap PICK_OF_THE_DAY_MAX + optional quartile spread.
# PICK_OF_THE_DAY_FULL_SLATE_PER_GAME=true
# PICK_OF_THE_DAY_MAX=5
# (capped at 10 in code)
# Spread picks across start-time quartiles so night games are not crowded out (default on).
# PICK_OF_THE_DAY_TIME_BUCKET_SPREAD=false
# After A/B slots, backfill with C (then D only if board game certainty %% is high). false = A/B-only.
# PICK_OF_THE_DAY_TRUST_RELAXATION=true
# Allow input-trust D when data_quality.certainty_pct clears this floor (default 90; a 94 chip qualifies).
# PICK_OF_THE_DAY_ALLOW_HIGH_CERTAINTY_D=true
# PICK_OF_THE_DAY_D_MIN_GAME_CERTAINTY_PCT=90

# Dashboard update jobs: max seconds per pipeline subprocess step (default 7200). Use 0 for no limit.
# MLB_PIPELINE_STEP_TIMEOUT_SEC=7200

# Green strip: optional minimum per-game board data certainty (0-100, from data_quality.certainty_pct).
# Leave unset for no extra gate. Example: only promote night games once inputs cross 84%.
# BOARD_GREEN_MIN_GAME_CERTAINTY_PCT=84
# Default: off (live board). Set true to freeze picks: the first qualifying green per game is stored at ingest-lock time
# so later refreshes do not swap that headline pick (db/migrations/028_board_green_snapshots.sql).
# BOARD_GREEN_SNAPSHOT_ENABLED=false
# When true, freeze each game's Top EV snapshot for Daily Results / ``prediction_outcomes_daily``
# (029_board_top_ev_snapshots.sql). The *clock* for when that snapshot is first written:
# - Omit BOARD_TOP_EV_SNAPSHOT_LOCK_MINUTES → use ``MLB_PREGAME_INGEST_LOCK_MINUTES`` (same moment ingest stops mutating
#   markets — lines are stable in DB afterward, consistent with green snapshots).
# - Set a smaller number (e.g. 12) → snapshot *later*, closer to first pitch; often stabler vs morning lines but less time
#   to bet after the number matches what the board showed.
# - Set a larger number (e.g. 90) → snapshot *earlier*; locks a pick while books may still move lines until ingest lock.
# BOARD_TOP_EV_SNAPSHOT_ENABLED=false
# BOARD_TOP_EV_SNAPSHOT_LOCK_MINUTES=
# Top EV run snapshots (030_board_run_snapshots.sql): default ON.
# Default true: freeze Top EV on the first pregame board load (same as green run eager) so headlines exist early.
# Set BOARD_TOP_EV_RUN_SNAPSHOT_EAGER=false to freeze only inside T−N (BOARD_TOP_EV_SNAPSHOT_LOCK_MINUTES / MLB_PREGAME_INGEST_LOCK_MINUTES).
# Set BOARD_TOP_EV_RUN_SNAPSHOT_ENABLED=false only if you want live Top EV all day.
# Green run snapshots default ON: catch-up after first pitch if no pregame row.
# BOARD_GREEN_RUN_SNAPSHOT_ENABLED=false
# Default true: freeze green strip on first pregame board load. Set false to freeze only inside the lock window.
# BOARD_GREEN_RUN_SNAPSHOT_EAGER=false
# BOARD_TOP_EV_RUN_SNAPSHOT_ENABLED=true
# BOARD_TOP_EV_RUN_SNAPSHOT_EAGER=true
# Pick-of-the-day run snapshots (032): default ON — first qualifying strict short-list pick per game freezes
# so Update Lineups / Rebuild Predictions does not swap that ticket pregame. Set EAGER=false to freeze only inside T−N.
# BOARD_PICK_OF_DAY_RUN_SNAPSHOT_ENABLED=true
# BOARD_PICK_OF_DAY_RUN_SNAPSHOT_EAGER=true
# Default true: omit batter TB **unders** from picks of the day (many books only list TB overs, e.g. FanDuel).
# Omit TB unders from green strip, watchlist, Top EV, and PoD (FanDuel-style). Legacy alias: PICK_OF_THE_DAY_BATTER_TB_OVERS_ONLY.
# BOARD_BATTER_TB_OVERS_ONLY=false
# Same for F5 away/home team total unders.
# BOARD_F5_TEAM_TOTAL_OVERS_ONLY=false
# Default true: do not freeze PoD / green / Top EV snapshots on F5 away/home team totals (often absent on FanDuel-class books).
# Stale DB rows are also ignored at merge time. Set false if your shop lists these and you want them in run snapshots.
# BOARD_SNAPSHOT_EXCLUDE_F5_TEAM_TOTALS=false
# Default true: if no other market has priced Top EV, allow F5 away/home team totals so Daily Results / Top EV are not blank overnight.
# TOP_EV_F5_TEAM_TOTAL_FALLBACK=false
# PICK_OF_THE_DAY_BATTER_TB_OVERS_ONLY=false
# Default true: when board target date is **after** today, picks of the day may include **soft green** strip cards
# (same thresholds as the green board) so tomorrow’s slate can show edges before strict EV clears.
# PICK_OF_THE_DAY_ALLOW_SOFT_GREEN_ON_FUTURE_SLATE=false
#
# After retraining: new weights live under MODEL_DIR, but the board reads prediction rows built by ``predict_*``.
# Run Refresh Everything or Update Lineups & Markets for the slate date so EV / best-bet math uses fresh outputs.
# Old rows in ``board_*_snapshots`` tables are ignored while flags are false; delete them if you want a clean DB.

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
